fun addFiledId(filterObj) = filterObj map ({
    field: (fieldId.dev[$.field] as String)  default ""
}++ $ - "field")
fun toString(obj, filCond)= ((obj map ($..)) map ((item, index) -> item map if($$ == 2)  ("'" ++ $ ++ "'") else $) map ($ joinBy " ")) joinBy filCond
---
({
    "and": toString(addFiledId(payload.andfilter), " and ") ,
    "or": toString(addFiledId(payload.orfilter), " or ")
}..) joinBy  " or "